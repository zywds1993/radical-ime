        <Button android:id="@+id/btn_overlay_candidate_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1:" android:textSize="14sp" android:padding="2dp" />
        <Button android:id="@+id/btn_overlay_candidate_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2:" android:textSize="14sp" android:padding="2dp" />
